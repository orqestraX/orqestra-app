# ─────────────────────────────────────────────────────────────────
# Orqestra Web App — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Supabase (get from supabase.com → Project Settings → API) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://orqestrax.com
NEXT_PUBLIC_APP_NAME=Orqestra

# ── Auth ─────────────────────────────────────────────────────────
# Supabase handles auth — these are just for reference
# Set redirect URLs in Supabase Dashboard → Auth → URL Configuration
# Allowed redirect: https://orqestrax.com/auth/callback

# ── Email (Resend for transactional emails) ───────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@orqestrax.com

# ── Payments ─────────────────────────────────────────────────────
# Cannabis-friendly payment processor (Paytron / Merrco)
PAYMENT_API_KEY=your-payment-api-key
PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# ── License Verification ──────────────────────────────────────────
# NMRLD API key (when available) or internal admin secret
LICENSE_VERIFY_SECRET=your-internal-secret

# ── Rate Limiting (Upstash Redis — upgrade from in-memory) ───────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Monitoring ────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─────────────────────────────────────────────────────────────────
# SECURITY RULES:
# 1. Never commit .env.local — it is in .gitignore
# 2. Rotate all keys immediately if they are ever exposed
# 3. Service role key bypasses RLS — guard it like a password
# 4. Add all vars to Vercel: Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────